# Production Environment Configuration
# IMPORTANT: This is an example file. Do not store actual secrets in this file.
# In production, use secure methods to inject these variables into the container.

# Core Configuration
ENVIRONMENT=production
ROOT_PATH=/api/v1
BASE_URL=https://auth.yourdomain.com
LOGGING_LEVEL=INFO

# Supabase Configuration

# Option 1: Cloud-hosted Supabase
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Option 2: Self-hosted Supabase
# Uncomment and configure these settings if using self-hosted Supabase
SUPABASE_SELF_HOSTED=true
SUPABASE_URL=https://your-domain.com
SUPABASE_ANON_KEY=your-anon-key  # From generate-keys.sh script
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # From generate-keys.sh script
SUPABASE_DB_HOST=db  # Use 'db' if within the same Docker network, otherwise the actual host address
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password

# Shared Supabase settings
SUPABASE_EMAIL_CONFIRMATION_REQUIRED=true
SUPABASE_AUTO_CONFIRM_NEW_USERS=false

# Database Configuration
AUTH_SERVICE_DATABASE_URL=postgresql+asyncpg://user:password@postgres-host:5432/auth_service

# JWT Configuration
M2M_JWT_SECRET_KEY=your-secure-random-secret-key-min-32-chars
M2M_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Rate Limiting Configuration
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_TOKEN=10/minute
RATE_LIMIT_PASSWORD_RESET=3/minute

# Redis Configuration (for token revocation)
REDIS_URL=redis://redis:6379/0

# Initial Admin Configuration (used only during first startup)
INITIAL_ADMIN_EMAIL=admin@yourdomain.com
INITIAL_ADMIN_PASSWORD=your-temporary-admin-password

# OAuth Configuration
OAUTH_STATE_COOKIE_NAME=supabase-auth-state
OAUTH_CALLBACK_ROUTE_BASE=/auth/users/oauth/callback

# Password Reset Configuration
PASSWORD_RESET_REDIRECT_URL=https://yourdomain.com/reset-password
