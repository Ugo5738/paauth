# Authentication Service Environment Variables

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Configuration
M2M_JWT_SECRET_KEY=your-secure-random-secret-key-min-32-chars

# Database Configuration
AUTH_SERVICE_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/auth_service

# API Configuration
ROOT_PATH=/api/v1
ENVIRONMENT=development  # Options: development, testing, production
BASE_URL=http://localhost:8000  # Must be HTTPS in production

# Rate Limiting Configuration
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=5/minute 
RATE_LIMIT_TOKEN=10/minute
RATE_LIMIT_PASSWORD_RESET=3/minute

# Admin User Configuration (for initial setup)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=strong-admin-password

# Logging Configuration
LOGGING_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# OAuth Configuration
OAUTH_STATE_COOKIE_NAME=supabase-auth-state
OAUTH_CALLBACK_ROUTE_BASE=/auth/users/oauth/callback

# Password Reset Configuration
PASSWORD_RESET_REDIRECT_URL=http://your-frontend-domain.com/reset-password

# JWT Token Expiry Configuration (in minutes)
M2M_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
